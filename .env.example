# Обязательно
BOT_TOKEN=your_telegram_bot_token

# База данных (по умолчанию SQLite в корне проекта)
DATABASE_URL=sqlite:///language_bot.db

# Переводчик Yandex Cloud Translate
YANDEX_TRANSLATE_API_KEY=your_yandex_translate_api_key
YANDEX_FOLDER_ID=your_yandex_folder_id

# Зарезервировано для будущих AI-функций (сейчас не используется)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Опционально: Telegram ID админов через запятую для /debug_* команд
# Если не задано, debug-команды доступны всем (удобно для локальной разработки)
ADMIN_TELEGRAM_IDS=
